# EAS archives from the monorepo root, so this file (not apps/mobile/.easignore)
# is what EAS reads. When .easignore exists it fully replaces .gitignore, so
# everything to exclude must be listed here.

# Dependencies (EAS installs fresh)
node_modules/
**/node_modules/

# Native build artifacts (regenerated by prebuild/CNG on EAS)
apps/mobile/ios/
apps/mobile/android/
apps/mobile/build/
**/build/
**/DerivedData/

# Next.js / API build output
apps/api/.next/
**/.next/
out/
**/out/

# Caches & misc
.expo/
**/.expo/
.turbo/
**/.turbo/
.maestro/
dist/
**/dist/
web-build/
*.tsbuildinfo
*.log
.DS_Store
.idea/
.vscode/

# Env (EAS injects its own)
.env
.env.local
**/.env.local
