# Mobile app (apps/mobile) — EXPO_PUBLIC_ vars are embedded in the client bundle.
# Auth is handled by better-auth on the API; the app derives the auth base URL
# from EXPO_PUBLIC_API_URL (stripping /api/v1), so no public auth key is needed.
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
# RevenueCat public SDK keys (PLAN §12) — all unset → mock plans, local entitlement.
# A Test Store key (test_…) is one key for both platforms and takes precedence;
# it exercises purchases without App Store Connect / Play, but cannot ship.
EXPO_PUBLIC_REVENUECAT_KEY=
# Production keys, required to ship — App Store (appl_…) and Play (goog_…).
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# Sentry (PLAN Phase 5) — unset → monitoring disabled
EXPO_PUBLIC_SENTRY_DSN=

# API (apps/api)
DATABASE_URL=postgres://user:pass@host/db
# better-auth (social sign-in). BETTER_AUTH_SECRET: a random 32+ char string
# (openssl rand -base64 32). BETTER_AUTH_URL: the API's public origin, must match
# the Google OAuth redirect host (e.g. https://www.littleloopapp.com; locally
# http://localhost:3001). Google creds come from the OAuth 2.0 Web client.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_API_KEY=
# Shared secret configured in the RevenueCat webhook's Authorization header
REVENUECAT_WEBHOOK_SECRET=
# Bearer secret for /api/cron/* (Vercel cron sends it automatically when set)
CRON_SECRET=
