# Mobile app (apps/mobile) — EXPO_PUBLIC_ vars are embedded in the client bundle
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
# RevenueCat public SDK keys (PLAN §12) — unset → mock plans, local entitlement
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
# Sentry (PLAN Phase 5) — unset → monitoring disabled
EXPO_PUBLIC_SENTRY_DSN=

# API (apps/api)
DATABASE_URL=postgres://user:pass@host/db
CLERK_SECRET_KEY=sk_test_xxx
YOUTUBE_API_KEY=
# Shared secret configured in the RevenueCat webhook's Authorization header
REVENUECAT_WEBHOOK_SECRET=
# Bearer secret for /api/cron/* (Vercel cron sends it automatically when set)
CRON_SECRET=
