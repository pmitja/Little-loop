# Neon Postgres — pooled connection string (rotate the previously exposed one!)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/littleloop?sslmode=require

# better-auth — the identity provider behind /api/auth/* and every /api/v1 session check.
# BETTER_AUTH_URL is the public origin this API is served from (no trailing slash);
# it must match the OAuth redirect URIs registered with the providers below.
BETTER_AUTH_URL=https://littleloopapp.com
# Random 32+ byte secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# Google sign-in (Web application OAuth client).
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
# Social sign-in is disabled at runtime if either value is missing.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign in with Apple — required by App Store guideline 4.8 because we offer Google.
# Apple sign-in is disabled at runtime unless all five values are set.
#   APPLE_CLIENT_ID  Services ID (Identifiers → Services IDs), e.g. app.littleloop.auth
#                    Return URL: ${BETTER_AUTH_URL}/api/auth/callback/apple
#   APPLE_TEAM_ID    10-character Apple Developer team id
#   APPLE_KEY_ID     Key ID of the "Sign in with Apple" key
#   APPLE_PRIVATE_KEY  Contents of AuthKey_XXXXXXXXXX.p8 (downloadable once).
#                    Keep the BEGIN/END lines; newlines may be escaped as \n.
#   APPLE_APP_BUNDLE_IDENTIFIER  iOS bundle id — the audience of the identity
#                    token the native sign-in sheet returns.
# The Apple client secret is a JWT minted from these at request time; there is
# no secret to paste and nothing to rotate by hand.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_APP_BUNDLE_IDENTIFIER=app.littleloop.mobile

# YouTube Data API v3 (server-only)
YOUTUBE_API_KEY=

# RevenueCat webhook: the exact string RevenueCat sends in the Authorization header
REVENUECAT_WEBHOOK_SECRET=
# App-specific RevenueCat SDK key used for server-side entitlement reconciliation
# when a webhook is delayed or was configured after an existing purchase.
REVENUECAT_API_KEY=appl_...

# Vercel cron auth (auto-injected by Vercel when set in project env)
CRON_SECRET=
