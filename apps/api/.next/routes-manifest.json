{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/v1/child-profiles/[id]",
      "regex": "^/api/v1/child\\-profiles/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/v1/child\\-profiles/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/v1/playlists/[id]",
      "regex": "^/api/v1/playlists/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/v1/playlists/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/v1/playlists/[id]/videos",
      "regex": "^/api/v1/playlists/([^/]+?)/videos(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/v1/playlists/(?<nxtPid>[^/]+?)/videos(?:/)?$"
    },
    {
      "page": "/api/v1/playlists/[id]/videos/order",
      "regex": "^/api/v1/playlists/([^/]+?)/videos/order(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/v1/playlists/(?<nxtPid>[^/]+?)/videos/order(?:/)?$"
    },
    {
      "page": "/api/v1/playlists/[id]/videos/[playlistVideoId]",
      "regex": "^/api/v1/playlists/([^/]+?)/videos/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPplaylistVideoId": "nxtPplaylistVideoId"
      },
      "namedRegex": "^/api/v1/playlists/(?<nxtPid>[^/]+?)/videos/(?<nxtPplaylistVideoId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/v1/watch-sessions/[id]",
      "regex": "^/api/v1/watch\\-sessions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/v1/watch\\-sessions/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/delete-account",
      "regex": "^/delete\\-account(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/delete\\-account(?:/)?$"
    },
    {
      "page": "/privacy",
      "regex": "^/privacy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}